{
  "name": "meal-appointment-api",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e .env.local -- tsx src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "start:e2e": "dotenv -e .env.e2e -- tsx src/server.ts",
    "db:migrate:test": "tsx scripts/apply-migrations.ts --env .env.test",
    "db:migrate:e2e": "tsx scripts/apply-migrations.ts --env .env.e2e",
    "db:seed:e2e": "tsx scripts/seed-database.ts --env .env.e2e",
    "test:unit": "jest --runInBand --testPathPattern tests/unit",
    "test:integration": "jest --runInBand --testPathPattern tests/integration"
  },
  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.3",
    "pg": "8.11.3",
    "pino": "8.17.0",
    "prom-client": "15.1.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.11",
    "@types/node": "20.11.19",
    "@types/pg": "8.11.2",
    "@types/supertest": "2.0.16",
    "dotenv-cli": "7.2.1",
    "jest": "29.7.0",
    "supertest": "6.3.4",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.7.0",
    "typescript": "5.3.3"
  }
}
